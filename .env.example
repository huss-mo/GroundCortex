# GroundCortex Configuration
# Copy this file to .env and fill in the values.
#
# IMPORTANT (Windows): TRL reads Jinja template files that contain non-ASCII
# characters. On Windows, Python defaults to the system code page (cp1252),
# which cannot decode those bytes. Set PYTHONUTF8=1 to force UTF-8 globally.
# This is harmless on macOS/Linux where UTF-8 is already the default.
PYTHONUTF8=1

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
GROUNDCORTEX_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
GROUNDCORTEX_OUTPUT_DIR=./adapters
GROUNDCORTEX_BUFFER_DB=./groundcortex.db

# ---------------------------------------------------------------------------
# Training  (defaults match hypothesis.py proven values)
# ---------------------------------------------------------------------------
GROUNDCORTEX_RANK=32
GROUNDCORTEX_ALPHA=64
GROUNDCORTEX_LEARNING_RATE=5e-4
GROUNDCORTEX_EPOCHS=25
GROUNDCORTEX_BATCH_SIZE=2

# true (default): inference model is offloaded before training, keeping peak
# memory at 1× base model. Inference and MCP endpoints return a 503 during
# training. Set to false only if you have enough VRAM to hold two copies of
# the base model simultaneously.
GROUNDCORTEX_OFFLOAD_DURING_TRAINING=true

# ---------------------------------------------------------------------------
# Ingestion - local files
# Comma-separated absolute paths to .md / .json / .txt files.
# GroundMemory files (MEMORY.md, USER.md, daily/*.md) are parsed by their
# timestamped-section format; all other files are treated as one section.
# ---------------------------------------------------------------------------
GROUNDCORTEX_SOURCE_PATHS=

# ---------------------------------------------------------------------------
# Ingestion - remote files
# Comma-separated HTTP URLs. Each URL must return raw file content (plain GET).
# Any HTTP server works: GroundMemory with a file-serving endpoint, a notes
# server, a plain static file host, etc.
# One optional bearer token is applied to all remote URLs.
# ---------------------------------------------------------------------------
GROUNDCORTEX_REMOTE_SOURCE_URLS=
GROUNDCORTEX_REMOTE_SOURCE_API_KEY=

# ---------------------------------------------------------------------------
# Cron scheduler
# Standard 5-field cron expression. Set ENABLED=false to disable.
# ---------------------------------------------------------------------------
GROUNDCORTEX_CRON_ENABLED=true
GROUNDCORTEX_CRON_SCHEDULE=0 2 * * *

# ---------------------------------------------------------------------------
# MCP server  (pipeline control - exposed to AI agents)
# EXPOSED_TOOLS: comma-separated subset of:
#   trigger_consolidation, get_cortex_status, switch_lora_version
# Leave empty to expose all three tools.
# ---------------------------------------------------------------------------
GROUNDCORTEX_MCP_HOST=127.0.0.1
GROUNDCORTEX_MCP_PORT=4343
GROUNDCORTEX_MCP_API_KEY=
GROUNDCORTEX_MCP_EXPOSED_TOOLS=

# ---------------------------------------------------------------------------
# Inference server  (OpenAI-compatible /v1/chat/completions)
# ---------------------------------------------------------------------------
GROUNDCORTEX_INFERENCE_HOST=127.0.0.1
GROUNDCORTEX_INFERENCE_PORT=4344
GROUNDCORTEX_INFERENCE_API_KEY=

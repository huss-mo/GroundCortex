.git
.gitignore
.env
.venv
.python-version
Dockerfile
docker-compose.yml

# Model weights - large, mounted at runtime via docker-compose volume.
# Not in .dockerignore by default just because a compose volume maps it;
# compose volumes are runtime mounts and do NOT affect the build context.
# This entry is what actually prevents the multi-GB cache from being sent
# to the Docker daemon on every build.
models/

# Runtime data - written by the running container, not needed at build time
adapters/
data/
groundcortex.db
groundcortex.db-shm
groundcortex.db-wal

# Tests - not installed in the image
tests/

# Reference material and examples - not needed in the image
examples/
_references/
_untracked/

# Python build artefacts
__pycache__
*.py[cod]
*.pyo
*.egg-info
dist/
build/

# Tooling caches
.pytest_cache
.mypy_cache
.ruff_cache
uv.lock

# Docs and non-essential files
*.md
!README.md

# OS
.DS_Store
Thumbs.db
